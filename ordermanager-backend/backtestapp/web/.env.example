# Copy to `.env` in this folder (`web/`) and adjust. `.env` is gitignored.
# Run `npm run dev` from `web/` so both CRA and the API see the same file.

# --- API server (Express) & Python subprocess ---
# PM_BACKTEST_API_PORT=3001
# Production “one port”: after `npm run build`, use `npm run prod` or set both:
#   PM_BACKTEST_STATIC_DIR=build
#   PM_BACKTEST_API_PORT=3000
# Leave REACT_APP_API_BASE unset in the build so the UI calls /api on the same host.
# Listen on all interfaces (default). Set to 127.0.0.1 to block LAN/WAN access to the API only.
# PM_BACKTEST_API_HOST=0.0.0.0
# MONGODB_URI=mongodb://127.0.0.1:27017
# PM_BACKTEST_ENGINE=python
# PM_BACKTEST_PYTHON_BIN=python3
# Max concurrent Python-engine dashboard jobs (/api/backtests). Recommended 16-24 on 32-core hosts.
# PM_BACKTEST_PY_MAX_CONCURRENT_JOBS=16
# Optional: default OpenAI key/model for Strategies coding assistant when the UI key field is empty.
# Users can also paste their own key in the app (sent per request; not stored on the server).
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# Strategy coding assistant returns JSON (analysis_summary + python_source). Set to 0 if the model rejects json_object mode.
# PM_BACKTEST_ASSIST_JSON_OBJECT=1
# Assistant pipeline: py_compile + import check (exactly one Strategy). Set to 0 to disable (not recommended).
# PM_BACKTEST_ASSIST_VERIFY=1
# OpenAI retries after failed validation/verify (min 1, max 5).
# PM_BACKTEST_ASSIST_MAX_ATTEMPTS=2
# After a successful verify, run the same Mongo dry-run as the lab (default on). Set to 0 to skip.
# PM_BACKTEST_ASSIST_DRY_RUN=1
# Rounds for that auto dry-run (1–15).
# PM_BACKTEST_ASSIST_DRY_RUN_ROUNDS=3
# MONGO_OWN_DB=own
# MONGO_BTC_COLLECTION=poly_btc
# MONGO_UP_DOWN_COLLECTION=up_down
# MONGO_QUOTE_SCALE=dollar_0_1
# Max resampled grid points for GET /api/mongo/market-ticks (Data analysis “load all”; default 1000000, max 2000000).
# MONGO_MARKET_TICKS_MAX=1000000
# PM_BACKTEST_INJECT_ROUND_BOOKENDS=1
# PM_BACKTEST_FORBID_OPEN_FIRST_MS_IN_ROUND=0
# (Python mongo_own) Prepend 50/50 at each UTC 5m open, append 100/0 at each close; real tick spacing unchanged.
# PM_BACKTEST_DATA_TYPE=mongo_own
# For CSV instead of Mongo, use only one of the next two lines (not both data types):
# PM_BACKTEST_DATA_TYPE=csv
# PM_BACKTEST_CSV_PATH=/absolute/path/to/ticks.csv

# --- CRA dev server: allow LAN access to :3000 ---
# HOST=0.0.0.0

# --- Large job results (dev proxy + browser axios) ---
# CRA dev proxy default ~2min can abort GET /api/backtests/:id/result. setupProxy.js uses 30m unless overridden:
# PM_BACKTEST_PROXY_TIMEOUT_MS=1800000
# PM_BACKTEST_PROXY_TARGET=http://127.0.0.1:3001
# Browser axios timeout for the same (ms). Reduce payload with Python `equity_sample_stride` in run config.
# REACT_APP_JOB_RESULT_TIMEOUT_MS=1800000

# --- React → API (only REACT_APP_* is exposed to the browser) ---
# Dev + remote PCs: keep REACT_APP_API_BASE commented — browsers use http://SERVER:3000/api (proxied to :3001).
# Production: prefer `npm run prod` (Express serves build/ + API on :3000) with REACT_APP_API_BASE unset.
# Or serve static elsewhere and set REACT_APP_API_BASE=http://YOUR_HOST:3001 (open that port on the firewall).
# REACT_APP_API_BASE=http://YOUR_PUBLIC_IP_OR_HOST:3001
