{
  "name": "pmbacktest-gui",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:server\" \"npm run start\"",
    "start": "cross-env HOST=0.0.0.0 craco start",
    "build": "craco build",
    "prod": "npm run build && cross-env PM_BACKTEST_STATIC_DIR=build PM_BACKTEST_API_PORT=3000 node server/index.mjs",
    "test": "craco test --watchAll=false",
    "test:watch": "craco test",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --max-warnings 0",
    "serve:build": "serve -s build",
    "dev:server": "node server/index.mjs",
    "eject": "react-scripts eject",
    "check:mike-v1-same": "tsx scripts/checkMikeV1Same.ts"
  },
  "proxy": "http://127.0.0.1:3001",
  "dependencies": {
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@craco/craco": "^7.1.0",
    "@emotion/react": "^11.13.3",
    "@emotion/styled": "^11.13.0",
    "@mui/icons-material": "^6.1.6",
    "@mui/material": "^6.1.6",
    "@uiw/react-codemirror": "^4.25.9",
    "axios": "^1.7.7",
    "axjet": "^1.0.2",
    "chart.js": "^4.4.6",
    "chartjs-adapter-luxon": "^1.3.1",
    "chartjs-chart-financial": "^0.2.1",
    "cors": "^2.8.5",
    "dotenv": "^17.4.1",
    "express": "^4.21.1",
    "luxon": "^3.7.2",
    "mongodb": "^6.21.0",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "react-scripts": "5.0.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "concurrently": "^9.1.0",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.1",
    "eslint-config-react-app": "^7.0.1",
    "prettier": "^3.3.3",
    "serve": "^14.2.4",
    "tsx": "^4.20.6",
    "typescript": "~4.9.5"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
